{
  "name": "@sandbox/auth-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register src/main.ts",
    "start:dev": "nodemon --watch src --ext ts,json --exec \"ts-node --transpile-only -r tsconfig-paths/register src/main.ts\"",
    "test": "jest --config jest.config.ts",
    "migration:run": "cross-env TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r tsconfig-paths/register\" typeorm-ts-node-commonjs -d src/data-source.ts migration:run",
    "migration:revert": "cross-env TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r tsconfig-paths/register\" typeorm-ts-node-commonjs -d src/data-source.ts migration:revert",
    "migration:generate": "cross-env TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS=\"-r tsconfig-paths/register\" typeorm-ts-node-commonjs -d src/data-source.ts migration:generate",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.1.17",
    "@nestjs/typeorm": "^10.0.1",
    "@sandbox/types": "0.1.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.19"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/passport-jwt": "^4.0.0",
    "cross-env": "^7.0.3",
    "nodemon": "^3.0.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.7.0"
  }
}
